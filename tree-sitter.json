{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "aoe2_rms",
      "camelcase": "Aoe2Rms",
      "title": "Aoe2 Random Map Script",
      "scope": "source.aoe2-rms",
      "file-types": ["rms", "rms2", "def", "inc", "bin"],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^aoe2-rms$",
      "class-name": "TreeSitterAoe2Rms"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "GPL-3.0-or-later",
    "description": "Tree-sitter grammar for Age of Empires II random map scripts (.rms).",
    "authors": [
      {
        "name": "T-West",
        "email": "twestura@gmail.com",
        "url": "https://www.twestaoe.net"
      }
    ],
    "links": {
      "repository": "https://github.com/twestura/tree-sitter-aoe2-rms"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
