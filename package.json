{
  "name": "tree-sitter-aoe2-rms",
  "version": "0.0.1",
  "description": "Tree-sitter grammar for Age of Empires II random map scripts (.rms).",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tree-sitter/tree-sitter-aoe2_rms.git"
  },
  "funding": "",
  "license": "GPL-3.0-or-later",
  "author": {
    "name": "T-West",
    "email": "twestura@gmail.com",
    "url": "https://www.twestaoe.net"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "aoe2_rms"
  ],
  "files": [
