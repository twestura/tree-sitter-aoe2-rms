#const MUD 76

start_random
  percent_chance 50 #define GRASS_MAP
  percent_chance 50 #define DESERT_MAP
end_random

if GRASS_MAP
  #const BASE_TERRAIN GRASS
  #const PRIMARY_FOREST FOREST
  #const CLIFF_TYPE CT_GRANITE
  #const HERD SHEEP
  #const LURE BOAR
  #const HUNT DEER
  #const PREDATOR WOLF
  #const STRAGGLER OAKTREE
elseif DESERT_MAP
  #const BASE_TERRAIN DESERT
