  #const CLIFF_TYPE CT_DESERT
  #const HERD DLC_GOAT
  #const LURE DLC_ELEPHANT
  #const HUNT DLC_ZEBRA
  #const PREDATOR ARABIAN_WOLF
  #const STRAGGLER PALMTREE
endif

<PLAYER_SETUP>
random_placement
behavior_version 2

<LAND_GENERATION>
base_terrain BASE_TERRAIN
create_player_lands {
  terrain_type BASE_TERRAIN
}

<ELEVATION_GENERATION>
create_elevation 4 {
  base_terrain BASE_TERRAIN
  number_of_tiles 3000
  number_of_clumps 20
}

<CLIFF_GENERATION>
cliff_type CLIFF_TYPE

<TERRAIN_GENERATION>
create_terrain PRIMARY_FOREST {
  base_terrain BASE_TERRAIN
  set_avoid_player_start_areas
  land_percent 12
  number_of_clumps 14
  set_scale_by_groups
  spacing_to_other_terrain_types 5
}

if GRASS_MAP
  create_terrain MUD {
    base_terrain BASE_TERRAIN
    land_percent 6
    number_of_clumps 8
    terrain_mask 2
  }
elseif DESERT_MAP
  create_terrain DIRT2 { base_terrain PRIMARY_FOREST land_percent 100 number_of_clumps 8196 terrain_mask 1 }
  create_terrain DIRT2 { base_terrain PRIMARY_FOREST land_percent 100 number_of_clumps 8196 terrain_mask 1 }
  create_terrain DIRT2 { base_terrain PRIMARY_FOREST land_percent 100 number_of_clumps 8196 terrain_mask 1 }
  create_terrain DIRT2 { base_terrain PRIMARY_FOREST land_percent 100 number_of_clumps 8196 terrain_mask 1 }
  create_terrain DIRT2 { base_terrain PRIMARY_FOREST land_percent 100 number_of_clumps 8196 terrain_mask 1 }
  create_terrain DIRT2 { base_terrain PRIMARY_FOREST land_percent 100 number_of_clumps 8196 terrain_mask 1 }
  create_terrain DIRT2 { base_terrain PRIMARY_FOREST land_percent 100 number_of_clumps 8196 terrain_mask 1 }
  create_terrain DIRT2 { base_terrain PRIMARY_FOREST land_percent 100 number_of_clumps 8196 terrain_mask 1 }
endif

