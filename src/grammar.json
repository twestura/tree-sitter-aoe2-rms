{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "aoe2_rms",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_definition"
      }
    },
    "_definition": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "define_statement"
        },
        {
          "type": "SYMBOL",
          "name": "const_statement"
        }
      ]
    },
    "define_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#define"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "const_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#const"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "integer"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "\\S+"
    },
    "integer": {
      "type": "PATTERN",
      "value": "[0-9]+"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r\\n]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}